@page
@model at.Pages.Ex01Model
@{
    ViewData["Title"] = "Ex01 - Delegate para Desconto";
}

<h2>Exercício 01 — Delegate para Cálculo de Descontos</h2>

<form method="post">
    <label for="price">Preço do Pacote: R$ </label>
    <input type="number" step="0.01" id="price" name="price" value="@Model.Price" />

    <button type="submit" class="btn btn-primary">Aplicar Desconto</button>
</form>

@if (Model.Result.HasValue)
{
    <p>Preço original do pacote: R$ @Model.Price.ToString("F2")</p>
    <p>Desconto do pacote de 10%: R$ @((Model.Price * 0.10m).ToString("F2"))</p>
    <p>Preço do pacote com desconto: R$ @Model.Result.Value.ToString("F2")</p>
}

<a href="/" class="btn btn-primary">Voltar</a>
