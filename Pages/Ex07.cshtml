@page
@model at.Pages.Ex07Model
@{
    ViewData["Title"] = "Lista de Pacotes";
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">
        @TempData["Message"]
    </div>
}

@if (Model.tourPackageList != null)
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Título</th>
                <th>Ano</th>
                <th>Preço</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tourPackage in Model.tourPackageList)
            {
                <tr>
                    <td>@tourPackage.Id</td>
                    <td>@tourPackage.Titulo</td>
                    <td>@tourPackage.CapacidadeMaxima</td>
                    <td>@tourPackage.Preco</td>
                    <td>
                        <a asp-page="PacoteTuristicoDetails" asp-route-id="@tourPackage.Id" class="btn btn-primary">Detalhes</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a href="/" class="btn btn-primary">Voltar</a>